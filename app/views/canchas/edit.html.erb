<% content_for :page_title, "Editar Cancha" %>

<div class="mx-auto md:w-2/3 w-full px-4">
  <%= link_to "Volver", configuracion_path, class: "text-primary dark:text-primary-dark hover:underline font-medium mb-4 inline-block" %>

  <h1 class="font-bold text-3xl mb-8 text-text-primary dark:text-text-primary-dark">Editar Cancha</h1>

  <%= form_with model: @cancha, url: configuracion_cancha_path(@cancha), method: :patch do |f| %>
    <%= render InputFieldComponent.new(
      label: "Nombre / Identificador",
      name: "cancha[name]",
      value: @cancha.name,
      error_message: @cancha.errors[:name].first,
      placeholder: "Ej: Cancha 1"
    ) %>

    <div class="my-5">
      <%= f.label :sport, "Deporte", class: "block text-sm font-medium text-text-secondary dark:text-text-secondary-dark mb-2" %>
      <%= f.select :sport, Cancha.sports.keys.map { |s| [s.humanize, s] }, {}, class: "block w-full rounded-md border border-border dark:border-border-dark px-3 py-3 text-base bg-surface dark:bg-surface-dark text-text-primary dark:text-text-primary-dark focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-primary-dark" %>
    </div>

    <div class="mt-8">
      <%= render ButtonPrimaryComponent.new(text: "Guardar Cambios") %>
    </div>
  <% end %>
</div>
