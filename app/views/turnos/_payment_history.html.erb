<div id="payment-history-<%= turno.id %>" class="mt-8">
  <h2 class="text-sm font-bold uppercase tracking-wide text-text-secondary dark:text-text-secondary-dark mb-2">
    Historial de pagos
  </h2>
  <div class="bg-surface dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg p-4 space-y-3">
    <% if turno.payments.empty? %>
      <p class="text-text-secondary dark:text-text-secondary-dark text-sm italic">Sin pagos registrados</p>
    <% else %>
      <% turno.payments.order(paid_at: :desc).each do |payment| %>
        <div class="flex items-center justify-between py-2 border-b border-border dark:border-border-dark last:border-0">
          <div>
            <span class="text-text-primary dark:text-text-primary-dark font-medium"><%= format_amount(payment.amount) %></span>
            <span class="text-text-secondary dark:text-text-secondary-dark text-sm ml-2"><%= l(payment.paid_at.to_date, format: "%d/%m/%Y", locale: :es) %></span>
          </div>
          <span class="text-text-secondary dark:text-text-secondary-dark text-sm"><%= payment.registered_by&.email_address || "—" %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
