<% content_for :page_title, "Calendario" %>

<div class="h-full flex flex-col">
  <!-- Navegación de Fechas -->
  <div class="flex items-center justify-between mb-6 px-4 md:px-0">
    <h1 class="font-bold text-3xl dark:text-white capitalize">
      <%= l(@date, format: "%A %d de %B", locale: :es) %>
    </h1>
    
    <div class="flex gap-2">
      <%= link_to calendario_path(date: @date.yesterday), class: "p-2 rounded-md bg-surface dark:bg-surface-dark border border-border dark:border-border-dark text-text-secondary dark:text-text-secondary-dark hover:bg-gray-50 dark:hover:bg-gray-800" do %>
        <span aria-hidden="true">&larr;</span>
        <span class="sr-only">Día anterior</span>
      <% end %>
      
      <%= link_to "Hoy", calendario_path(date: Date.current), class: "px-4 py-2 rounded-md bg-surface dark:bg-surface-dark border border-border dark:border-border-dark text-text-primary dark:text-text-primary-dark font-medium hover:bg-gray-50 dark:hover:bg-gray-800" %>
      
      <%= link_to calendario_path(date: @date.tomorrow), class: "p-2 rounded-md bg-surface dark:bg-surface-dark border border-border dark:border-border-dark text-text-secondary dark:text-text-secondary-dark hover:bg-gray-50 dark:hover:bg-gray-800" do %>
        <span aria-hidden="true">&rarr;</span>
        <span class="sr-only">Día siguiente</span>
      <% end %>
    </div>
  </div>

  <% if @canchas.empty? %>
    <div class="flex-grow flex items-center justify-center text-text-secondary dark:text-text-secondary-dark p-8 text-center">
      <p>No hay canchas configuradas en este complejo.<br>
      <% if Current.user.owner? %>
        <%= link_to "Ir a Configuración", configuracion_path, class: "text-primary dark:text-primary-dark font-medium hover:underline mt-2 inline-block" %>
      <% end %>
      </p>
    </div>
  <% else %>
    <!-- Contenedor del Calendario -->
    <div class="flex-grow overflow-hidden flex flex-col -mx-5 md:mx-0">
      
      <!-- Headers de Canchas (Sticky) -->
      <div class="flex overflow-x-auto snap-x snap-mandatory md:overflow-visible md:snap-none scrollbar-hide border-b border-border dark:border-border-dark bg-background dark:bg-background-dark z-10 sticky top-0" id="calendar-headers">
        <!-- Espacio vacío para la columna de horas en desktop -->
        <div class="hidden md:block w-20 flex-shrink-0"></div>

        <% @canchas.each do |cancha| %>
          <div class="w-full md:w-auto md:flex-1 md:min-w-0 flex-shrink-0 snap-start md:snap-none px-4 py-3 text-center border-r border-border dark:border-border-dark last:border-r-0 md:last:border-r">
            <h2 class="font-bold text-text-primary dark:text-text-primary-dark truncate"><%= cancha.name %></h2>
            <p class="text-xs text-text-secondary dark:text-text-secondary-dark uppercase tracking-wider"><%= humanize_sport(cancha.sport) %></p>
          </div>
        <% end %>
      </div>

      <!-- Grilla de Horarios y Turnos -->
      <div class="flex-grow overflow-y-auto">
        <div class="flex overflow-x-auto snap-x snap-mandatory md:overflow-visible md:snap-none scrollbar-hide" id="calendar-grid">

          <!-- Columna de Horas (Solo Desktop) -->
          <div class="hidden md:flex flex-col w-20 flex-shrink-0 border-r border-border dark:border-border-dark bg-surface dark:bg-surface-dark/50 sticky left-0 z-10">
            <% @hours.each do |hour| %>
              <div class="h-32 border-b border-border dark:border-border-dark flex items-start justify-center pt-2">
                <span class="text-xs font-medium text-text-secondary dark:text-text-secondary-dark"><%= format('%02d:00', hour) %></span>
              </div>
            <% end %>
          </div>

          <!-- Columnas de Canchas -->
          <% @canchas.each do |cancha| %>
            <div class="w-full md:w-auto md:flex-1 md:min-w-0 flex-shrink-0 snap-start md:snap-none flex flex-col border-r border-border dark:border-border-dark last:border-r-0 md:last:border-r relative">
              <% @hours.each do |hour| %>
                <div class="h-32 border-b border-border dark:border-border-dark p-2 relative group">
                  <!-- Etiqueta de hora para mobile -->
                  <div class="md:hidden absolute top-2 right-2 px-1.5 py-0.5 bg-surface dark:bg-surface-dark rounded text-[10px] font-medium text-text-secondary dark:text-text-secondary-dark z-10 opacity-70">
                    <%= format('%02d:00', hour) %>
                  </div>
                  
                  <% turno = @turnos[[cancha.id, hour]] %>
                  
                  <% if turno %>
                    <%= render CardTurnoComponent.new(turno: turno) %>
                  <% else %>
                    <!-- Slot Vacío -->
                    <%= link_to new_turno_path(cancha_id: cancha.id, date: @date, hour: hour), class: "w-full h-full rounded-lg border-2 border-dashed border-border dark:border-border-dark flex items-center justify-center text-text-secondary dark:text-text-secondary-dark hover:bg-primary/5 dark:hover:bg-primary-dark/10 hover:border-primary/50 dark:hover:border-primary-dark/50 hover:text-primary dark:hover:text-primary-dark transition-colors text-sm text-center px-4" do %>
                      Cancha libre — tocá para crear un turno
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
          
        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  /* Ocultar scrollbar pero permitir scroll */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  // Script simple para sincronizar el scroll horizontal entre los headers y la grilla
  document.addEventListener('turbo:load', () => {
    const headers = document.getElementById('calendar-headers');
    const grid = document.getElementById('calendar-grid');
    
    if (headers && grid) {
      grid.addEventListener('scroll', () => {
        headers.scrollLeft = grid.scrollLeft;
      });
      headers.addEventListener('scroll', () => {
        grid.scrollLeft = headers.scrollLeft;
      });
    }
  });
</script>
