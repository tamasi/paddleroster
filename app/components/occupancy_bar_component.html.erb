<div class="occupancy-bar flex items-center gap-3" data-testid="occupancy-bar">
  <span class="w-28 shrink-0 text-sm font-medium text-text-primary dark:text-text-primary-dark"><%= label %></span>
  <div class="flex-1 h-2 rounded-full bg-black/10 dark:bg-white/10 overflow-hidden">
    <div class="h-full rounded-full bg-success dark:bg-success-dark" style="width: <%= percentage %>%"></div>
  </div>
  <span class="w-12 shrink-0 text-right text-lg font-bold tabular-nums text-text-primary dark:text-text-primary-dark"><%= percentage %>%</span>
</div>
